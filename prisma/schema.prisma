// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STAFF
  CASHIER
}

model User {
  id             String          @id @default(cuid())
  username       String          @unique
  passwordHash   String
  role           Role
  isActive       Boolean         @default(true)
  failedAttempts Int             @default(0)
  lockedUntil    DateTime?
  objectId       String?
  object         BusinessObject? @relation(fields: [objectId], references: [id])
  organizationId String?
  organization   Organization?   @relation(fields: [organizationId], references: [id])
  reports        DailyReport[]   @relation("ReportAuthor")
  revisions      ReportRevision[] @relation("RevisionEditor")
  soldVouchers   Voucher[]       @relation("VoucherSeller")
  redeemedVouchers Voucher[]     @relation("VoucherRedeemer")
  createdAt      DateTime        @default(now())

  @@index([objectId])
  @@index([organizationId])
}

model BusinessObject {
  id              String               @id @default(cuid())
  nameUz          String
  nameRu          String
  slug            String               @unique
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  users           User[]
  reports         DailyReport[]
  organizationLinks OrganizationObject[]
  vouchers        Voucher[]
}

model DailyReport {
  id                 String                    @id @default(cuid())
  date               DateTime                  @db.Date
  objectId           String
  object             BusinessObject            @relation(fields: [objectId], references: [id])
  visitorCount       Int                       @default(0)
  cashAmount         Decimal                   @default(0) @db.Decimal(14, 2)
  cardAmount         Decimal                   @default(0) @db.Decimal(14, 2)
  transferAmount     Decimal                   @default(0) @db.Decimal(14, 2)
  qrAmount           Decimal                   @default(0) @db.Decimal(14, 2)
  totalAmount        Decimal                   @db.Decimal(14, 2)
  comment            String?                   @db.Text
  extra              Json?
  createdById        String
  createdBy          User                      @relation("ReportAuthor", fields: [createdById], references: [id])
  organizationEntries ReportOrganizationEntry[]
  revisions          ReportRevision[]
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@unique([objectId, date])
  @@index([date])
}

model Organization {
  id                String                    @id @default(cuid())
  nameUz            String
  nameRu            String
  slug              String                    @unique
  isActive          Boolean                   @default(true)
  commissionPercent Decimal                   @default(20) @db.Decimal(5, 2)
  createdAt         DateTime                  @default(now())
  entries           ReportOrganizationEntry[]
  objectLinks       OrganizationObject[]
  cashiers          User[]
  vouchers          Voucher[]
}

model OrganizationObject {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  objectId       String
  object         BusinessObject @relation(fields: [objectId], references: [id], onDelete: Cascade)

  @@unique([organizationId, objectId])
}

model ReportOrganizationEntry {
  id             String       @id @default(cuid())
  reportId       String
  report         DailyReport  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  visitorCount   Int          @default(0)

  @@unique([reportId, organizationId])
}

model ReportRevision {
  id         String      @id @default(cuid())
  reportId   String
  report     DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  snapshot   Json
  editedById String
  editedBy   User        @relation("RevisionEditor", fields: [editedById], references: [id])
  editedAt   DateTime    @default(now())

  @@index([reportId])
}

enum VoucherStatus {
  UNUSED
  USED
}

model Voucher {
  id                String         @id @default(cuid())
  code              String         @unique
  objectId          String
  object            BusinessObject @relation(fields: [objectId], references: [id])
  guestCount        Int
  cashAmount        Decimal        @default(0) @db.Decimal(14, 2)
  cardAmount        Decimal        @default(0) @db.Decimal(14, 2)
  transferAmount    Decimal        @default(0) @db.Decimal(14, 2)
  qrAmount          Decimal        @default(0) @db.Decimal(14, 2)
  totalAmount       Decimal        @db.Decimal(14, 2)
  organizationId    String
  organization      Organization   @relation(fields: [organizationId], references: [id])
  commissionPercent Decimal        @db.Decimal(5, 2)
  commissionAmount  Decimal        @db.Decimal(14, 2)
  status            VoucherStatus  @default(UNUSED)
  soldById          String
  soldBy            User           @relation("VoucherSeller", fields: [soldById], references: [id])
  soldAt            DateTime       @default(now())
  usedAt            DateTime?
  usedById          String?
  usedBy            User?          @relation("VoucherRedeemer", fields: [usedById], references: [id])

  @@index([objectId])
  @@index([organizationId])
  @@index([status])
}
